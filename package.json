{
  "name": "rocketdrop",
  "version": "1.0.0",
  "description": "Large file uploader to Cloudflare R2 via multipart upload",
  "scripts": {
    "dev": "concurrently -k -n API,Vite -c cyan,magenta \"node server.js\" \"vite\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "node server.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.15.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-router-dom": "^5.3.3",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.0"
  }
}
